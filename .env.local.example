# Local development:
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# SITE_URL=http://127.0.0.1:3000
#
# Production / Netlify:
NEXT_PUBLIC_SITE_URL=https://nullcost.xyz
SITE_URL=https://nullcost.xyz

# Run `npx supabase status -o env` after `npm run supabase:start`
# to fill these for local development. Use hosted Supabase values in
# Netlify or any production deploy.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

NULLCOST_REVIEWER_EMAILS=
